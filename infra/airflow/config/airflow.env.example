# Airflow runtime paths
AIRFLOW_REPO_ROOT=/opt/retail-analytics-lakehouse
AIRFLOW_PYTHON_BIN=python
AIRFLOW_DBT_BIN=dbt
AIRFLOW_DBT_SELECTOR=phase2_governed_models
AIRFLOW_SPARK_CONN_ID=spark_default

# Batch ETL orchestration inputs/outputs
AIRFLOW_RAW_INPUT_PATH_TEMPLATE=data/generated/transactions.csv.gz
AIRFLOW_RAW_INPUT_FORMAT=csv
AIRFLOW_OUTPUT_TARGET=local
AIRFLOW_OUTPUT_BASE_PATH=data/lakehouse
AIRFLOW_TABLE_FORMAT=parquet
AIRFLOW_TARGET_ENV=dev

# Dataset-aware scheduling URIs
AIRFLOW_DATASET_RAW_TRANSACTIONS=s3://retail-loyalty-lakehouse/dev/bronze/transactions
AIRFLOW_DATASET_GOLD_DAILY_REVENUE=s3://retail-loyalty-lakehouse/dev/gold/daily_revenue_by_store
AIRFLOW_DATASET_GOLD_TOP_PRODUCTS=s3://retail-loyalty-lakehouse/dev/gold/top_10_products_by_day
AIRFLOW_DATASET_GOLD_CUSTOMER_LTV=s3://retail-loyalty-lakehouse/dev/gold/customer_lifetime_value
AIRFLOW_DATASET_PHASE3_COMPACTION=s3://retail-loyalty-lakehouse/dev/ops/compaction
AIRFLOW_DATASET_ML_SALES_MODEL=s3://retail-loyalty-lakehouse/dev/ml/sales-revenue-model

# Phase 3 compaction controls
AIRFLOW_COMPACTION_DATASETS=silver/transactions,gold/daily_revenue_by_store,gold/top_10_products_by_day,gold/customer_lifetime_value
AIRFLOW_COMPACTION_TARGET_FILE_SIZE_MB=256
SPARK_WORKLOAD_PROFILE=cost_saver

# PyTorch model retraining controls
AIRFLOW_ML_GOLD_DAILY_REVENUE_PATH=data/lakehouse/gold/daily_revenue_by_store
AIRFLOW_ML_MODEL_OUTPUT_DIR=artifacts/models/sales_revenue_predictor
AIRFLOW_ML_PREDICTION_OUTPUT_FILE=artifacts/models/predictions/sales_predictions_{{ ds_nodash }}.jsonl
AIRFLOW_ML_TRAIN_EPOCHS=30
AIRFLOW_ML_TRAIN_BATCH_SIZE=64
AIRFLOW_ML_TRAIN_LEARNING_RATE=0.001
AIRFLOW_ML_TRAIN_VALIDATION_RATIO=0.2

# Promotion workflow artifacts
AIRFLOW_PROMOTION_ARTIFACT_TEMPLATE=data/promotions/{source_env}/{release_version}/ready.flag
AIRFLOW_PROMOTION_RECORD_TEMPLATE=data/promotions/history/{target_env}/{release_version}.json

# Run metadata (local path or s3:// URI)
AIRFLOW_RUN_METADATA_PATH_TEMPLATE=data/ops/run_metadata/{dag_id}/ds={ds}/{run_id_safe}.json
AIRFLOW_BACKFILL_MAX_DAYS=90

# Deployment metadata for run records
DEPLOYMENT_ENV=dev
DEPLOYMENT_GIT_SHA=
DEPLOYMENT_GIT_REF=
DEPLOYMENT_RELEASE_VERSION=
DEPLOYMENT_IMAGE_TAG=
DEPLOYMENT_IMAGE_DIGEST=
DBT_MANIFEST_PATH=

# OpenLineage (Spark job runtime wiring)
OPENLINEAGE_ENABLED=false
OPENLINEAGE_URL=http://marquez:5000/api/v1/lineage
OPENLINEAGE_NAMESPACE=retail-analytics-lakehouse

# Alerting
# AIRFLOW_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# AIRFLOW_ALERT_SNS_TOPIC_ARN=arn:aws:sns:ca-central-1:123456789012:retail-airflow-alerts
