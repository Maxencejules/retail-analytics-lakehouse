# Environment profile
APP_ENV=dev

# AWS region and profile (AWS default credential chain)
AWS_REGION=ca-central-1
AWS_DEFAULT_REGION=ca-central-1
AWS_PROFILE=retail-dev
AWS_SDK_LOAD_CONFIG=1

# Lakehouse paths
LAKEHOUSE_BUCKET=retail-loyalty-lakehouse-dev
LAKEHOUSE_PREFIX=
BRONZE_PATH=s3://retail-loyalty-lakehouse-dev/bronze
SILVER_PATH=s3://retail-loyalty-lakehouse-dev/silver
GOLD_PATH=s3://retail-loyalty-lakehouse-dev/gold
CHECKPOINT_PATH=s3://retail-loyalty-lakehouse-dev/_checkpoints

# Phase 3 Spark performance profile
SPARK_WORKLOAD_PROFILE=balanced
SPARK_MIN_EXECUTORS=2
SPARK_INITIAL_EXECUTORS=4
SPARK_MAX_EXECUTORS=20
SPARK_SHUFFLE_PARTITIONS=200
COMPACTION_TARGET_FILE_SIZE_MB=256

# OpenLineage runtime wiring
OPENLINEAGE_ENABLED=true
OPENLINEAGE_URL=http://marquez:5000/api/v1/lineage
OPENLINEAGE_NAMESPACE=retail-analytics-lakehouse
