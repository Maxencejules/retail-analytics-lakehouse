# Environment profile
APP_ENV=dev

# AWS region and profile (AWS default credential chain)
AWS_REGION=ca-central-1
AWS_DEFAULT_REGION=ca-central-1
AWS_PROFILE=retail-dev
AWS_SDK_LOAD_CONFIG=1

# Lakehouse paths
LAKEHOUSE_BUCKET=retail-loyalty-lakehouse-dev
LAKEHOUSE_PREFIX=
BRONZE_PATH=s3://retail-loyalty-lakehouse-dev/bronze
SILVER_PATH=s3://retail-loyalty-lakehouse-dev/silver
GOLD_PATH=s3://retail-loyalty-lakehouse-dev/gold
CHECKPOINT_PATH=s3://retail-loyalty-lakehouse-dev/_checkpoints

