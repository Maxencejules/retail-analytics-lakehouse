# Environment profile
APP_ENV=prod

# AWS region and profile (AWS default credential chain)
AWS_REGION=ca-central-1
AWS_DEFAULT_REGION=ca-central-1
AWS_PROFILE=retail-prod
AWS_SDK_LOAD_CONFIG=1

# Lakehouse paths
LAKEHOUSE_BUCKET=retail-loyalty-lakehouse-prod
LAKEHOUSE_PREFIX=
BRONZE_PATH=s3://retail-loyalty-lakehouse-prod/bronze
SILVER_PATH=s3://retail-loyalty-lakehouse-prod/silver
GOLD_PATH=s3://retail-loyalty-lakehouse-prod/gold
CHECKPOINT_PATH=s3://retail-loyalty-lakehouse-prod/_checkpoints

