{
  "profile_name": "balanced",
  "spark_conf": {
    "spark.sql.adaptive.enabled": true,
    "spark.dynamicAllocation.enabled": true,
    "spark.dynamicAllocation.minExecutors": 2,
    "spark.dynamicAllocation.initialExecutors": 4,
    "spark.dynamicAllocation.maxExecutors": 20,
    "spark.dynamicAllocation.shuffleTracking.enabled": true,
    "spark.sql.shuffle.partitions": 200,
    "spark.sql.files.maxPartitionBytesMb": 128,
    "spark.sql.autoBroadcastJoinThresholdMb": 10,
    "spark.speculation": true,
    "spark.scheduler.mode": "FAIR"
  },
  "workload_classes": [
    {
      "name": "critical_streaming",
      "profile_override": "high_throughput",
      "sla_minutes": 5
    },
    {
      "name": "daily_batch",
      "profile_override": "balanced",
      "sla_minutes": 120
    },
    {
      "name": "offpeak_compaction",
      "profile_override": "cost_saver",
      "sla_minutes": 240
    }
  ]
}
